{
  "name": "payments-api",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && if [ -d docs ]; then cp -r docs dist/; fi",
    "start": "node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate:run": "ts-node ./node_modules/typeorm/cli.js migration:run -d src/infra/db/typeorm/datasource.ts",
    "migrate:gen": "ts-node ./node_modules/typeorm/cli.js migration:generate -d src/infra/db/typeorm/datasource.ts src/infra/db/typeorm/migrations/auto",
    "migrate:run:prod": "node ./node_modules/typeorm/cli.js migration:run -d dist/infra/db/typeorm/datasource.js",
    "worker": "tsx watch src/infra/messaging/bullmq/outbox-worker.ts",
    "deploy:railway": "npm install && npm run build && npm run migrate:run:prod && npm run start"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "axios": "^1.7.2",
    "bullmq": "^5.7.7",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mysql2": "^3.10.0",
    "reflect-metadata": "^0.1.14",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.20",
    "yaml": "^2.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.4",
    "@types/swagger-ui-express": "^4.1.6",
    "ts-node": "^10.9.2",
    "tslib": "^2.6.3",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^1.6.1"
  }
}
