NODE_ENV=development
PORT=3000

# Use DB_HOST=db when running inside docker-compose
DB_HOST=localhost
DB_PORT=3306
DB_USER=payments
DB_PASS=payments
DB_NAME=payments

# Use REDIS_HOST=redis when running inside docker-compose
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USER=
REDIS_PASSWORD=

# Fila BullMQ: use nome diferente em dev quando compartilhar Redis com prod (ex.: outbox_development)
# Assim só o worker local processa seus jobs; prod continua na fila "outbox".
# OUTBOX_QUEUE_NAME=outbox_development

# Auth (OBRIGATÓRIO - mínimo 32 caracteres)
AUTH_TOKEN_SECRET=your-super-secret-key-minimum-32-characters-long-for-security
AUTH_TOKEN_TTL=3600

# CORS - Configuração de origem permitida (separar múltiplas origens por vírgula)
# Use '*' para permitir todas as origens (não recomendado em produção)
CORS_ORIGIN=*

# Rate limit (opcional - valores padrão abaixo)
# Global: requisições por IP por janela (proteção anti-abuso)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=100
# Login/reset senha: tentativas por IP (anti brute-force; só conta falhas)
# RATE_LIMIT_AUTH_WINDOW_MS=900000
# RATE_LIMIT_AUTH_MAX=5
# Registro / solicitação de reset: por IP por hora
# RATE_LIMIT_REGISTRATION_WINDOW_MS=3600000
# RATE_LIMIT_REGISTRATION_MAX=3
# Webhooks: por IP por minuto
# RATE_LIMIT_WEBHOOK_WINDOW_MS=60000
# RATE_LIMIT_WEBHOOK_MAX=100

# Swagger basic auth (required in production to access /docs)
SWAGGER_USERNAME=admin
SWAGGER_PASSWORD=changeme

# Asaas - Configuração Principal
ASAAS_API_KEY=your_asaas_token_here
ASAAS_BASE_URL=https://www.asaas.com/api/v3

# Asaas - Webhooks (obrigatório em produção quando o módulo schools está ativo)
# Token para validar requisições de webhook do Asaas (header asaas-access-token ou query token)
# IMPORTANTE: Deve ser DIFERENTE de AUTH_TOKEN_SECRET por segurança
# O sistema valida e rejeita se forem iguais
ASAAS_WEBHOOK_TOKEN=your-webhook-token-here-different-from-auth-token-secret

# Asaas - Webhooks de Subcontas (Opcional)
# URL base para webhooks de subcontas (escolas)
ASAAS_SUBACCOUNT_WEBHOOK_URL=https://your-api.com/integrations/asaas
ASAAS_SUBACCOUNT_WEBHOOK_EMAIL=webhooks@your-domain.com
ASAAS_SUBACCOUNT_WEBHOOK_AUTH_TOKEN=subaccount-webhook-token
ASAAS_SUBACCOUNT_WEBHOOK_SEND_TYPE=SEQUENTIALLY
ASAAS_SUBACCOUNT_WEBHOOK_API_VERSION=3
ASAAS_SUBACCOUNT_WEBHOOK_EVENTS=PAYMENT_CREATED,PAYMENT_UPDATED,PAYMENT_CONFIRMED,PAYMENT_RECEIVED
ASAAS_SUBACCOUNT_ACCOUNT_WEBHOOK_URL=https://your-api.com/integrations/asaas
ASAAS_SUBACCOUNT_ACCOUNT_WEBHOOK_EVENTS=ACCOUNT_APPROVED,ACCOUNT_PENDING,ACCOUNT_REJECTED

# Mailchimp/Mandrill Email Configuration (Priority: Mailchimp > SendGrid > Nodemailer)
MAILCHIMP_API_KEY=your-mandrill-api-key
MAILCHIMP_FROM_EMAIL=email@minhaaulaoficial.com.br
MAILCHIMP_FROM_NAME=MAILDRILL

# SendGrid Email Configuration (Fallback)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Nodemailer Email Configuration (Fallback local)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# Twilio - WhatsApp (Opcional)
# Para enviar notificações via WhatsApp: configure e enfileire jobs tipo whatsapp_notification.
# Sandbox: use o número do sandbox (ex: whatsapp:+14155238886) e opt-in enviando a mensagem indicada ao número.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Firebase - Push Notifications (Opcional)
# JSON completo da service account do Firebase
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project",...}

# Storage (S3/Railway) - Opcional
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_REGION=
STORAGE_BUCKET=
STORAGE_ENDPOINT=

# Módulos da Aplicação
# Valores: all, auth, admin, payments, schools, students (separar por vírgula para múltiplos)
APP_MODULES=all

# Testes - URLs para scripts de teste
TEST_WEBHOOK_URL=http://localhost:3000
API_URL=http://localhost:3000
