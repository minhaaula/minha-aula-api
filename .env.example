#
# Exemplo de configuração.
# Copie para `.env` e ajuste para seu ambiente:
#   cp .env.example .env
#

NODE_ENV=development
PORT=3000

# Documentação Docusaurus servida em GET /portal (opcional). Default: ./website/build relativo ao cwd.
# PORTAL_STATIC_DIR=/var/www/minha-aula-portal

# Módulos da aplicação
# Valores: all, auth, admin, payments, schools, students (separar por vírgula para múltiplos)
APP_MODULES=all

# Proxy / IP real (IMPORTANTE em produção atrás de proxy/load balancer)
# Se sua infra envia X-Forwarded-For, habilite trust proxy para o rate limit e req.ip funcionarem corretamente.
# Valores aceitos:
# - true | false
# - número de hops confiáveis (ex.: 1)
# - string do Express (ex.: loopback, linklocal, uniquelocal, ou uma subnet)
# Em produção o default do servidor é 1; em dev o default é false.
# TRUST_PROXY=1

# URL base do frontend (usado para links de reset de senha e emails)
# FRONTEND_BASE_URL=https://app.minha-escola.com
FRONTEND_BASE_URL=http://localhost:5173

# Banco de dados (MySQL)
# Use DB_HOST=db quando rodar dentro do docker-compose
DB_HOST=localhost
DB_PORT=3306
DB_USER=payments
DB_PASS=payments
DB_NAME=payments

# Redis (BullMQ / jobs)
# Use REDIS_HOST=redis quando rodar dentro do docker-compose
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USER=
REDIS_PASSWORD=

# Fila BullMQ: use nome diferente em dev quando compartilhar Redis com prod (ex.: outbox_development)
# Assim só o worker local processa seus jobs; prod continua na fila "outbox".
# OUTBOX_QUEUE_NAME=outbox_development

# Auth (OBRIGATÓRIO - mínimo 32 caracteres)
AUTH_TOKEN_SECRET=your-super-secret-key-minimum-32-characters-long-for-security
AUTH_TOKEN_TTL=3600

# CORS - Configuração de origem permitida (separar múltiplas origens por vírgula)
# Use '*' para permitir todas as origens (não recomendado em produção)
CORS_ORIGIN=*

# Rate limit (opcional - valores padrão já aplicados)
# Global: requisições por IP por janela (proteção anti-abuso)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=100
# Login/reset senha: tentativas por IP (anti brute-force; só conta falhas)
# RATE_LIMIT_AUTH_WINDOW_MS=900000
# RATE_LIMIT_AUTH_MAX=5
# Registro / solicitação de reset: por IP por hora
# RATE_LIMIT_REGISTRATION_WINDOW_MS=3600000
# RATE_LIMIT_REGISTRATION_MAX=3
# Webhooks: por IP por minuto
# RATE_LIMIT_WEBHOOK_WINDOW_MS=60000
# RATE_LIMIT_WEBHOOK_MAX=100

# Swagger (/docs) — basic auth em produção
SWAGGER_USERNAME=admin
SWAGGER_PASSWORD=changeme

# (Opcional) URL de produção exibida no Swagger/OpenAPI (servers[...])
# Pode usar qualquer uma das duas:
# SWAGGER_PROD_URL=https://api.minha-escola.com
# API_PROD_URL=https://api.minha-escola.com

# Asaas — Configuração principal
# Obs.: ASAAS_API_KEY é obrigatória quando módulos payments/schools/students estiverem ativos.
ASAAS_API_KEY=your_asaas_token_here
# ASAAS_BASE_URL é opcional (padrão: https://www.asaas.com/api/v3)
ASAAS_BASE_URL=https://www.asaas.com/api/v3
# Opcional: se true, o Asaas volta a enviar notificações (e-mail/SMS etc.) ao pagador (PIX/boleto) e para subcontas novas.
# Padrão (omitido ou false): pagador com notificationDisabled + PUT /customers/{id}; subconta com notificationDisabled no POST /accounts.
# ASAAS_NOTIFY_CUSTOMER_ON_PAYMENT=true

# Asaas — Webhooks (OBRIGATÓRIO em produção quando o módulo schools está ativo)
# Token para validar requisições de webhook do Asaas (header asaas-access-token/x-asaas-access-token ou query token)
# IMPORTANTE: Deve ser DIFERENTE de AUTH_TOKEN_SECRET por segurança (o sistema valida e rejeita se forem iguais).
ASAAS_WEBHOOK_TOKEN=your-webhook-token-here-different-from-auth-token-secret

# Asaas — Webhooks de subcontas (opcional; usado ao criar subcontas)
# URL base para webhooks de subcontas (ex.: https://api.minha-escola.com/integrations/asaas)
ASAAS_SUBACCOUNT_WEBHOOK_URL=https://your-api.com/integrations/asaas
ASAAS_SUBACCOUNT_WEBHOOK_EMAIL=webhooks@your-domain.com
ASAAS_SUBACCOUNT_WEBHOOK_SEND_TYPE=SEQUENTIALLY
ASAAS_SUBACCOUNT_WEBHOOK_AUTH_TOKEN=subaccount-webhook-token
ASAAS_SUBACCOUNT_WEBHOOK_API_VERSION=3
ASAAS_SUBACCOUNT_WEBHOOK_EVENTS=PAYMENT_CREATED,PAYMENT_UPDATED,PAYMENT_CONFIRMED,PAYMENT_RECEIVED
ASAAS_SUBACCOUNT_WEBHOOK_NAME=Webhook para cobranças

# Webhook de contas (pode usar a mesma URL base ou outra)
ASAAS_SUBACCOUNT_ACCOUNT_WEBHOOK_URL=https://your-api.com/integrations/asaas
ASAAS_SUBACCOUNT_ACCOUNT_WEBHOOK_EVENTS=ACCOUNT_STATUS_GENERAL_APPROVAL_APPROVED,ACCOUNT_STATUS_GENERAL_APPROVAL_REJECTED,ACCOUNT_STATUS_GENERAL_APPROVAL_AWAITING_APPROVAL,ACCOUNT_STATUS_GENERAL_APPROVAL_PENDING
ASAAS_SUBACCOUNT_ACCOUNT_WEBHOOK_NAME=Webhook para contas

# Email Providers (prioridade: Mailchimp > Twilio SendGrid > Nodemailer)
#
# Mailchimp/Mandrill
MAILCHIMP_API_KEY=
MAILCHIMP_FROM_EMAIL=
MAILCHIMP_FROM_NAME=
#
# Twilio SendGrid (fallback)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=
#
# Nodemailer (fallback local/dev)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
# From padrão (opcional)
EMAIL_FROM=

# Twilio — WhatsApp (opcional)
# Para enviar notificações via WhatsApp: configure e enfileire jobs tipo whatsapp_notification.
# Sandbox: use o número do sandbox (ex.: whatsapp:+14155238886) e opt-in enviando a mensagem indicada ao número.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Twilio Content API — templates WhatsApp (Content SID HX... no Console)
# HX... (Content SID na página do template). Não use o friendly name (ex.: solicitacao_matricula).
TWILIO_CONTENT_SID_SOLICITACAO_MATRICULA=
# Se o template usar {{1}}…{{4}} em vez de nome/escola/curso/aluno: TWILIO_SOLICITACAO_MATRICULA_USE_NUMBERED_VARS=1
TWILIO_CONTENT_SID_MENSALIDADE_EM_ATRASO=
TWILIO_CONTENT_SID_MENSALIDADE_VENCE_HOJE=
TWILIO_CONTENT_SID_MENSALIDADE_DISPONIVEL=
TWILIO_CONTENT_SID_NOTIFICATIONS_WELCOME=
# OTP escola: preferir TWILIO_CONTENT_SID_MESSAGE_OPT_IN; legado: TWILIO_WHATSAPP_MESSAGE_OPT_IN_CONTENT_SID
TWILIO_CONTENT_SID_MESSAGE_OPT_IN=
# Corpo único em {{1}} (alternativa a variáveis 1–8 em cobranca.template)
# TWILIO_COBRANCA_CONTENT_USE_FULL_BODY=true
TWILIO_WHATSAPP_MESSAGE_OPT_IN_CONTENT_SID=

# Twilio Verify — OTP WhatsApp (opcional; prioridade sobre template Content acima)
# Service SID (VA…) em Verify → Services. Ex.: https://www.twilio.com/docs/verify/whatsapp
TWILIO_VERIFY_SERVICE_SID=

# Firebase — Push Notifications (opcional)
# JSON completo da service account do Firebase
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project",...}

# Storage (S3/Railway) - opcional
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_REGION=
STORAGE_BUCKET=
# Endpoint é opcional (útil em Railway/MinIO)
STORAGE_ENDPOINT=

# Testes / scripts (opcional)
TEST_WEBHOOK_URL=http://localhost:3000
API_URL=http://localhost:3000
TEST_EMAIL_TO=contato@minhaaulaoficial.com.br
TEST_EMAIL=test@example.com
TEST_WHATSAPP_TO=11999887766

# Linear automation (optional)
# GraphQL API token from Linear.
LINEAR_API_TOKEN=
# Label used to select issues to process.
LINEAR_LABEL_NAME=
# Optional team key filter (example: ENG, API).
LINEAR_TEAM_KEY=
# Optional issue status filter, separated by comma.
# LINEAR_STATES=Todo,Backlog
# Base branch used to create work branches.
LINEAR_BASE_BRANCH=main
# External command that performs the task implementation.
# The command receives env vars like LINEAR_TASK_ID, LINEAR_TASK_TITLE, LINEAR_TASK_BRANCH and LINEAR_TASK_DESCRIPTION.
# LINEAR_TASK_COMMAND=node scripts/run-codex-linear-task.mjs
# When true, opens a PR using GitHub CLI after commit.
# LINEAR_CREATE_PR=false
# When true, commits automatically without asking for confirmation after task execution.
# LINEAR_AUTO_COMMIT=false
# Commit message template. Supports {id} and {title}.
# LINEAR_COMMIT_TEMPLATE=feat({id}): {title}
